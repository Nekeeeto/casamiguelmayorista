WOO_URL="https://casamiguel.uy"
WOO_KEY="ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
WOO_SECRET="cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Sync security
WHOLESALE_SYNC_TOKEN="set-a-random-long-token"
WOO_WEBHOOK_SECRET="set-a-random-webhook-secret"

# Ofertas semanales (cron GET /api/cron/ofertas-semanales): mismo Bearer WHOLESALE_SYNC_TOKEN o header x-vercel-cron en Vercel.
# WEEKLY_OFFERS_SKIP_WOO=1  # no llama a Woo (solo guarda estado en Supabase; útil en dev)

# Optional: max WooCommerce products loaded in admin (faster). Omit or use 5 for tests.
# WHOLESALE_CATALOG_LIMIT=5
# Full catalog (slow on large stores):
# WHOLESALE_CATALOG_LIMIT=all

# Woo: estados de pedido incluidos en analíticas y gráfico rentabilidad web (coma-separada).
# Por defecto: completed, processing + slugs sugeridos espera-mvd, espera-interior, espera-pickup.
# Listá slugs reales con: GET .../wp-json/wc/v3/reports/orders/totals
# WOO_ORDER_STATUSES=completed,processing,espera-mvd,proceso-mvd
# WOO_ORDER_STATUSES_EXTRA=enviado-dac,para-retirar
# WOO_ORDER_STATUSES_SIN_ESPERA_SUGERIDA=1

# Optional: Google AI (Gemini 3.1 Flash Image) — packshot / galería en /herramientas/imagenes-gemini
# GEMINI_API_KEY="AIza..."

# Optional (required only to upload NEW local images from admin PIM):
# WordPress Application Password credentials for /wp-json/wp/v2/media
# WP_APP_USER="editor@casamiguel.uy"
# WP_APP_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"

# =========================================================================
# WhatsApp Marketing (/herramientas/whatsapp-marketing)
# =========================================================================
# Fuente primaria = tabla whatsapp_config en Supabase (editable desde la UI).
# Estas variables sirven como fallback si la tabla está vacía (bootstrap) y
# para levantar el módulo en dev sin pasar antes por la UI.
#
# Se obtienen en Meta Business → WhatsApp → API de Cloud.
# WHATSAPP_PHONE_NUMBER_ID="123456789012345"
# WHATSAPP_BUSINESS_ACCOUNT_ID="987654321098765"
# WHATSAPP_ACCESS_TOKEN="EAAG..."  # Token permanente del sistema-user
# WHATSAPP_WEBHOOK_VERIFY_TOKEN="token-random-largo"
# WHATSAPP_APP_SECRET="app-secret-de-la-app-de-meta"  # Para validar firma HMAC del webhook

# Webhook WooCommerce de pedidos (order.updated) → /api/webhooks/woocommerce-pedidos
# Reutiliza WOO_WEBHOOK_SECRET (definido arriba) para validar la firma HMAC
# SHA-256 en base64 del header x-wc-webhook-signature.

# FunnelKit / Outgoing webhook carrito abandonado → /api/webhooks/funnelkit-carrito-abandonado
# Mismo valor en header X-Funnelkit-Secret, Authorization: Bearer … o ?token=…
# FUNNELKIT_CART_WEBHOOK_SECRET="otro-secreto-largo-aleatorio"

# Wiser / WiserNotify u otro POST de reseñas → /api/webhooks/wiser-review-request
# Headers aceptados: X-Wiser-Secret, X-WiserNotify-Secret, X-Webhook-Secret, Authorization: Bearer …, ?token=…
# WISER_REVIEW_WEBHOOK_SECRET="secreto-largo-aleatorio"
